rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "sharmakanishk43369@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "skanishk608@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'phoneNumber', 'role']) &&
             data.uid is string &&
             data.phoneNumber is string &&
             data.role in ['admin', 'user', 'driver'];
    }

    function isValidRide(data) {
      return data.keys().hasAll(['userId', 'pickup', 'drop', 'vehicleType', 'status', 'timestamp']) &&
             data.userId is string &&
             data.pickup is string &&
             data.drop is string &&
             data.vehicleType in ['auto', 'bike', 'smallcab', 'car'] &&
             data.status in ['pending', 'accepted', 'completed', 'cancelled'] &&
             data.timestamp is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /rides/{rideId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRide(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }
  }
}
